{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "4482874578267956767"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "metadata": {
        "description": "Base name used to derive resource names when explicit overrides are not supplied."
      }
    },
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Deployment environment label used for naming/tagging (for example: dev, test, prod)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure location for all resources."
      }
    },
    "dnsSubscriptionId": {
      "type": "string",
      "metadata": {
        "description": "Subscription ID that contains the Azure DNS zones updated by the function app."
      }
    },
    "dnsResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Resource group name that contains the Azure DNS zones updated by the function app."
      }
    },
    "functionAppName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional override for Function App name."
      }
    },
    "storageAccountName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional override for Storage Account name."
      }
    },
    "appInsightsName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional override for Application Insights name."
      }
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional override for Log Analytics workspace name."
      }
    },
    "functionPlanName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional override for Flex Consumption plan name."
      }
    },
    "dnsZoneNames": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Optional DNS zone names to grant DNS Zone Contributor at zone scope in the shared DNS resource group."
      }
    }
  },
  "variables": {
    "baseToken": "[toLower(replace(replace(parameters('baseName'), '-', ''), '_', ''))]",
    "envToken": "[toLower(replace(replace(parameters('environmentName'), '-', ''), '_', ''))]",
    "uniqueSuffix": "[take(uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('baseName'), parameters('environmentName')), 6)]",
    "functionAppNameDerived": "[take(format('{0}-func-{1}-{2}', variables('baseToken'), parameters('environmentName'), variables('uniqueSuffix')), 60)]",
    "storageAccountNameDerived": "[take(format('{0}{1}{2}', variables('baseToken'), variables('envToken'), variables('uniqueSuffix')), 24)]",
    "appInsightsNameDerived": "[take(format('{0}-appi-{1}', variables('baseToken'), parameters('environmentName')), 260)]",
    "logAnalyticsWorkspaceNameDerived": "[take(format('{0}-law-{1}', variables('baseToken'), parameters('environmentName')), 63)]",
    "functionPlanNameDerived": "[take(format('{0}-plan-{1}', variables('baseToken'), parameters('environmentName')), 40)]",
    "functionAppNameResolved": "[if(empty(parameters('functionAppName')), variables('functionAppNameDerived'), parameters('functionAppName'))]",
    "storageAccountNameResolved": "[if(empty(parameters('storageAccountName')), variables('storageAccountNameDerived'), toLower(parameters('storageAccountName')))]",
    "appInsightsNameResolved": "[if(empty(parameters('appInsightsName')), variables('appInsightsNameDerived'), parameters('appInsightsName'))]",
    "logAnalyticsWorkspaceNameResolved": "[if(empty(parameters('logAnalyticsWorkspaceName')), variables('logAnalyticsWorkspaceNameDerived'), parameters('logAnalyticsWorkspaceName'))]",
    "functionPlanNameResolved": "[if(empty(parameters('functionPlanName')), variables('functionPlanNameDerived'), parameters('functionPlanName'))]",
    "deploymentStorageContainerName": "function-releases",
    "storageBlobDataOwnerRoleDefinitionId": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountNameResolved')]",
