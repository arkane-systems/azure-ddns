      "type": "string",
      "value": "[variables('storageAccountNameResolved')]"
    },
    "applicationInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsNameResolved')), '2020-02-02').ConnectionString]"
    },
    "dnsZoneScopedRoleAssignments": {
      "type": "array",
      "copy": {
        "count": "[length(parameters('dnsZoneNames'))]",
        "input": "[format('/subscriptions/{0}/resourceGroups/{1}/providers/Microsoft.Network/dnsZones/{2}', parameters('dnsSubscriptionId'), parameters('dnsResourceGroup'), parameters('dnsZoneNames')[copyIndex()])]"
      }
    }
  }
}