        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppNameResolved')), '2024-04-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppNameResolved'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountNameResolved'))]"
      ]
    },
    {
      "condition": "[not(empty(parameters('dnsZoneNames')))]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "dns-zone-rbac",
      "subscriptionId": "[parameters('dnsSubscriptionId')]",
      "resourceGroup": "[parameters('dnsResourceGroup')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "dnsZoneNames": {
            "value": "[parameters('dnsZoneNames')]"
          },
          "principalId": {
            "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppNameResolved')), '2024-04-01', 'full').identity.principalId]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "15295430200209936555"
            }
          },
          "parameters": {
            "dnsZoneNames": {
              "type": "array",
              "metadata": {
                "description": "DNS zone names that should grant DNS Zone Contributor to the Function App identity."
              }
            },
            "principalId": {
              "type": "string",
              "metadata": {
                "description": "Managed identity principal ID of the Function App."
              }
            }
          },
          "variables": {
            "dnsZoneContributorRoleDefinitionId": "befefa01-2a29-4197-83a8-272ff33ce314"
          },
          "resources": [
            {
              "copy": {
                "name": "dnsZoneRoleAssignments",
                "count": "[length(parameters('dnsZoneNames'))]"
              },
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.Network/dnsZones', parameters('dnsZoneNames')[copyIndex()])]",
              "name": "[guid(resourceId('Microsoft.Network/dnsZones', parameters('dnsZoneNames')[copyIndex()]), parameters('principalId'), variables('dnsZoneContributorRoleDefinitionId'))]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('dnsZoneContributorRoleDefinitionId'))]",
                "principalId": "[parameters('principalId')]",
                "principalType": "ServicePrincipal"
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppNameResolved'))]"
      ]
    }
