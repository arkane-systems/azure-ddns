      "value": "[variables('functionAppNameResolved')]"
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppNameResolved')), '2024-04-01', 'full').identity.principalId]"
