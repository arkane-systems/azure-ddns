            },
            {
              "name": "DNS_SUBSCRIPTION_ID",
              "value": "[parameters('dnsSubscriptionId')]"
            },
            {
              "name": "DNS_RESOURCE_GROUP",
              "value": "[parameters('dnsResourceGroup')]"
            },
            {
              "name": "CONFIG_PATH",
              "value": "config/dyndns.json"
            },
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', variables('storageAccountNameResolved'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountNameResolved')), '2023-05-01').keys[0].value)]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsNameResolved'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', split(format('{0}/default/{1}', variables('storageAccountNameResolved'), variables('deploymentStorageContainerName')), '/')[0], split(format('{0}/default/{1}', variables('storageAccountNameResolved'), variables('deploymentStorageContainerName')), '/')[1], split(format('{0}/default/{1}', variables('storageAccountNameResolved'), variables('deploymentStorageContainerName')), '/')[2])]",
        "[resourceId('Microsoft.Web/serverfarms', variables('functionPlanNameResolved'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountNameResolved'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
