        "functionAppConfig": {
          "runtime": {
            "name": "dotnet-isolated",
            "version": "8.0"
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": 40,
            "instanceMemoryMB": 2048
          },
          "deployment": {
